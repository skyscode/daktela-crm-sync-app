# ============================================================
# .gitignore — Files and folders excluded from git tracking
# ============================================================
# 
#   .env              — Contains real credentials (DB password, API token).
#                       Never commit this. Use .env.example as the template.
#
#   vendor/           — PHP dependencies installed by Composer.
#                       Recreated with: composer install
#
#   logs/             — Runtime log files. Large, machine-generated, not source.
#   logs/*.log        — All .log files inside logs/
#
#   .phpunit.result.cache — PHPUnit test cache, developer-machine specific.
#
#   .DS_Store         — macOS folder metadata, irrelevant to the project.
#   Thumbs.db         — Windows thumbnail cache, irrelevant to the project.
# ============================================================

.env
vendor/
logs/*.log
.phpunit.result.cache
.DS_Store
Thumbs.db
test_db.php
sync_once.php
truncate.php
diagnose.php
check_contacts.php
check_dist.php
count_contacts.php
.claude/
