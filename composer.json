{
    "name": "skyscode/daktela-crm-sync",
    "description": "Daktela CRM sync service — pulls contacts, tickets and statuses from the Daktela API, persists them in MySQL, and exposes a local REST API. Background daemon syncs every hour.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "monolog/monolog": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "post-install-cmd": [
            "docker-php-ext-install pdo_mysql 2>/dev/null || true"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
