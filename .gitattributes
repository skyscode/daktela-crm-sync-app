# .gitattributes — Normalise line endings across Windows/Linux/macOS
# All text files stored as LF in the repo; checked out as CRLF on Windows.
* text=auto
*.php text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.env.example text eol=lf
*.htaccess text eol=lf
