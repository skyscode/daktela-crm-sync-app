# --- Daktela API ---
# Full Daktela API base URL, e.g. https://mycompany.daktela.com/api/v6
DAKTELA_API_URL=https://your-instance.daktela.com/api/v6

# API access token generated in Daktela admin panel
DAKTELA_ACCESS_TOKEN=your-access-token-here

# Daktela API endpoint paths (these rarely change)
DAKTELA_CONTACTS_ENDPOINT=CrmContacts
DAKTELA_CONTACT_STATUSES_ENDPOINT=CrmStatuses
DAKTELA_TICKETS_ENDPOINT=Tickets
DAKTELA_TICKET_STATUSES_ENDPOINT=TicketStatuses

# Set to false only in local dev if Daktela uses a self-signed cert
GUZZLE_VERIFY_SSL=true

# --- MySQL Database (phpMyAdmin) ---
# Host: use 'localhost' for shared hosting (cPanel/phpMyAdmin on same server)
# or the database server IP if using a remote MySQL server
DB_HOST=localhost
DB_PORT=3306

# Database name created in phpMyAdmin
DB_NAME=your_database_name

# MySQL user with full privileges on the above database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4

# --- Logging ---
# Path is relative to project root; make sure the logs/ directory is writable
LOG_PATH=logs/app.log

# One of: debug, info, warning, error
LOG_LEVEL=info

# --- Sync ---
# How often the background sync daemon runs, in seconds (3600 = 1 hour)
SYNC_INTERVAL=3600

# --- Application ---
# The live domain where this app is hosted, used for CORS and redirects
APP_URL=https://yourdomain.com

# Set to 'production' on live server, 'development' locally
APP_ENV=production
